[bar/bottom]
margin-top = 0
enable-ipc = true

width = 100%
height = 30
offset-x = 0
offset-y = 0
bottom = true
locale = en_US.UTF-8

background = #F01c1e20
foreground = #ff85a2

font-0 = Hack:size=10;4
font-1 = FontAwesome:size=10;4.5
font-2 = "Noto Sans CJK JP Medium:size=10;4"

modules-left = hlwm
modules-center = date
modules-right = battery

underline-size = 3

spacing = 1
padding-left = 0
padding-right = 1
module-margin-left = 1
module-margin-right = 1

override-redirect = false

[module/date]
locale=en_US.UTF-8
type = internal/date
interval = 1
time = %H:%M
date = %Y%{T3}年%{T-}%m%{T3}月%{T-}%d%{T3}日%{T-}
label= %{F#AAA}%date%%{F-} %{F#ff85a2}%time%%{F-}
format-padding = 1
format-foreground = #ff85a2

[module/battery]
type = internal/battery

; This is useful in case the battery never reports 100% charge
full-at = 99

battery = BAT0
adapter = ADP1

[module/hlwm]
type = custom/script
exec = ~/.config/polybar/scripts/hlwm.sh
tail = true
scroll-up = herbstclient use_index -1 --skip-visible &
scroll-down = herbstclient use_index +1 --skip-visible &

; vim:ft=dosini
