[frame]
	width = 0
	color = "#B0BEC5"

[urgency_low]
	background = "#ffffff"
	foreground = "#546E7A"
	timeout = 10

[urgency_normal]
	background = "#ffffff"
	foreground = "#B0BEC5"
	timeout = 10

[urgency_critical]
	background = "#FF1744"
	foreground = "#CFD8DC"
	timeout = 0

[global]
	format = "<b>%s</b>\n%b\n%p"
	geometry = "300x5-10+10"

	font = Roboto 10
	allow_markup = yes
	plain_text = no
	sort = no
	indicate_hidden = yes
	alignment = left
	bounce_freq = 0
	show_age_threshold = 60
	word_wrap = yes
	ignore_newline = no
	transparency = 0
	shrink = no
	monitor = 0
	follow = none
	show_indicators = no
	line_height = 0
	notification_height = 0
	separator_height = 0
	padding = 8
	horizontal_padding = 16
	separator_color = frame
	icon_position = left

	idle_threshold = 120
	sticky_history = yes
	history_length = 20

	icon_folders = /usr/share/icons/hicolor/16x16
	startup_notification = false
	dmenu = /usr/bin/dmenu -p dunst:
	browser = /usr/bin/firefox -new-tab

[shortcuts]
	close = ctrl+space
	close_all = ctrl+shift+space
	history = ctrl+grave
